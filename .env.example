# Stripe keys — get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONE_TIME=
STRIPE_PRICE_SUB=

# OpenAI key — get this from https://platform.openai.com
OPENAI_API_KEY=

# Supabase project (required for auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Your deployed app URL (used for Stripe redirect URLs)
APP_BASE_URL=https://your-app.onrender.com

# API base URL — leave empty when frontend and backend are on the same origin
VITE_API_BASE_URL=

# Port the Express server listens on (Render sets this automatically)
PORT=10000
